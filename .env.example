# Vision OCR backend configuration
# The app sends the image directly to this OpenAI-compatible endpoint.

# API base URL. Examples:
#   Local LMStudio: http://localhost:1234/v1
#   Docker reaching host LMStudio: http://host.docker.internal:1234/v1
#   Ollama Cloud: https://ollama.com/v1
#   NVIDIA NIM: https://integrate.api.nvidia.com/v1
OCR_URL=http://localhost:1234/v1

# Model name. Examples:
#   LMStudio: gemma4-26b-a4b-qat-uncensored-hauhaucs-balanced-mtp
#   Ollama Cloud: gemma4:31b-cloud
#   NVIDIA NIM: google/gemma-4-31b-it
OCR_MODEL=gemma4-26b-a4b-qat-uncensored-hauhaucs-balanced-mtp

# API key. Leave blank for local LMStudio/Ollama; required for cloud endpoints.
OCR_API_KEY=
